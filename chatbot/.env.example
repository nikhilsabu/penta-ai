# Copy this file to .env and set real values.
# Never commit .env to version control.

DB_HOST=127.0.0.1
DB_NAME=pentame_chatbot
DB_USER=root
DB_PASS=

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Public chatbot API key (sent from the widget via X-API-Key header)
CHATBOT_API_KEY=change_me_to_a_random_secret

# Admin panel login password
ADMIN_PASSWORD=change_me_admin_password

# Comma-separated allowed origins for CORS, or * for all
ALLOWED_ORIGINS=*
